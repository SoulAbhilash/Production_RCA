# Local dev: copy to .env (gitignored). OS env always overrides this file.

# --- Gemini (default path; Google Gen AI SDK) ---
# From Google AI Studio or a service account key usable as API key where supported.
GEMINI_API_KEY=
# Optional model id (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Corporate TLS / custom CA for Gemini (path inside container or VM)
# GEMINI_TLS_CA_BUNDLE=/etc/ssl/corp/ca.pem
# Or reuse: LLM_TLS_CA_BUNDLE=/path/to/ca.pem
# Lab only: GEMINI_TLS_VERIFY=false

# Same as GEMINI_API_KEY; recognized by Google clients if you prefer this name.
# GOOGLE_API_KEY=

# --- Optional: OpenAI-compatible HTTP gateway (all three required) ---
# LLM_GATEWAY_BASE_URL=https://your-gateway.example.com
# LLM_GATEWAY_API_KEY=
# LLM_GATEWAY_MODEL=
# LLM_TLS_VERIFY=true
# LLM_TLS_CA_BUNDLE=/path/to/corp-ca.pem

# --- Optional: OpenAI direct ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# LLM_MAX_RETRIES=3
# LLM_RETRY_DELAY_S=5
