# Create the real Secret in-cluster (do not commit credentials).
# Password must match in both keys — Postgres sidecar + app DATABASE_URL (127.0.0.1).
#
#   kubectl -n poc create secret generic demo-app-db \
#     --from-literal=POSTGRES_PASSWORD='YOUR_PASSWORD' \
#     --from-literal=DATABASE_URL='postgresql+psycopg://app:YOUR_PASSWORD@127.0.0.1:5432/app'
#
# For throwaway labs without a PVC, use the same secret after switching the Deployment
# volume to emptyDir (see deploy/k8s/README.md).
apiVersion: v1
kind: Secret
metadata:
  name: demo-app-db
  namespace: poc
type: Opaque
stringData:
  POSTGRES_PASSWORD: "CHANGEME"
  DATABASE_URL: "postgresql+psycopg://app:CHANGEME@127.0.0.1:5432/app"
