# Create the real Secret in-cluster (do not commit credentials):
# kubectl -n poc create secret generic demo-app-db \
#   --from-literal=DATABASE_URL='postgresql+psycopg://USER:PASS@HOST:5432/DB'
apiVersion: v1
kind: Secret
metadata:
  name: demo-app-db
  namespace: poc
type: Opaque
stringData:
  DATABASE_URL: "postgresql+psycopg://app:CHANGEME@CHANGEME:5432/app"
